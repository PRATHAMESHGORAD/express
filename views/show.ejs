<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <center>
        <h2>Employee Details &nbsp;&nbsp; <a href="/addEmp">Add Emp</a></h2>
        <table border="1">
        <tr>
            <th>Name</th>
            <th>Salary</th>
            <th>Department</th>
        </tr>
            <% data.forEach(d => { %>
                <tr>
                <td><%= d.name %></td>
                <td><%= d.salary %></td>
                <td><%= d.department %></td>
             </tr>
            <% }) %>
        </table>
    </center>
</body>
</html>